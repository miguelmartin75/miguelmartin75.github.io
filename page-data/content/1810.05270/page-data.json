{"componentChunkName":"component---src-templates-post-template-tsx","path":"/content/1810.05270","result":{"pageContext":{"slug":"/content/1810.05270","markdownRemark":{"htmlAst":{"type":"root","children":[{"type":"element","tagName":"h1","properties":{},"children":[{"type":"text","value":"Summary"}]},{"type":"text","value":"\n"},{"type":"element","tagName":"p","properties":{},"children":[{"type":"text","value":"States LTH's method of finding a winning ticket is not necessary"}]},{"type":"text","value":"\n"},{"type":"element","tagName":"ul","properties":{},"children":[{"type":"text","value":"\n"},{"type":"element","tagName":"li","properties":{},"children":[{"type":"text","value":"It's commonly believed in literature that you have to: train, then prune and then fine-tune"}]},{"type":"text","value":"\n"},{"type":"element","tagName":"li","properties":{},"children":[{"type":"text","value":"But this is not necessary for unstructured pruning"}]},{"type":"text","value":"\n"},{"type":"element","tagName":"li","properties":{},"children":[{"type":"text","value":"Instead, you can find a better set of hparams for the optimization method, e.g. for SGD"}]},{"type":"text","value":"\n"}]},{"type":"text","value":"\n"},{"type":"element","tagName":"p","properties":{},"children":[{"type":"text","value":"For unstructured pruning this does not scale to ImageNet. They do not know why. Only comparable perf for smaller datasets (and models?)"}]}],"data":{"quirksMode":false}},"frontmatter":{"date":null,"title":"Rethinking the value of network pruning","state":null,"slug":null,"tags":"paper ml","source":"https://arxiv.org/abs/1810.05270","code":null},"fields":{"slug":"/content/1810.05270"}}}},"staticQueryHashes":["2744905544"]}